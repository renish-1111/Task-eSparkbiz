<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <style>
      .block {
        padding: 30px 40px;
        border: 2px solid;
        cursor: pointer;
      }
    </style>
  </head>

  <body> 
    <table>
      <tr>
        <td>
          <div class="block" id="focus">
            <input id="runonfocus" value="onfocus()" />
          </div>
        </td>
        <td>
          <div class="block" id="runonclick">onclick()</div>
        </td>
        <td>
          <div class="block" id="runondblclick">ondblclick()</div>
        </td>
        <td>
          <div class="block"><input id="runonblur" value="onblur()" /></div>
        </td>
        <td>
          <div class="block"><input id="runonchange" value="runonchange()" /></div>
        </td>
      </tr>
      <tr>
        <td>
          <div class="block" id="color">
            onmouseover()/onmouseout()
          </div>
        </td>
        <td>
          <div class="block" id="mouseenter">
            onmouseenter()/onmouseleave()
          </div>
        </td>
        <td>
          <div class="block" id="mouseup">
            onmouseup()/onmousedown()
          </div>
        </td>
        <td><div class="block" id="runoncontextmenu">oncontextmenu()</div></td>
        <td>
          <div class="block" id="mousemove">
            onmousemove()/onmouseout()
          </div>
        </td>
      </tr>
      <tr>
        <td>
          <div class="block">
            <input
              id="runonpaste"
              placeholder="paste than see runonpaste()"
            />
            <p id="paste"></p>
          </div>
        </td>
        <td>
          <div class="block"><details id="runontoggle">toggle</details></div>
        </td>
        <td>
          <div class="block">
            <form id="runonsubmit">
              <input type="submit" value="submit" />
            </form>
          </div>
        </td>
        <td>
          <div class="block"><input id="runoninput" value="input" /></div>
        </td>
        <td>
          <div class="block" id="runoncopy">dont copy this</div>
        </td>
      </tr>
      <tr>
        <td>
          <div class="block" id="drag" draggable="true">drag</div>
        </td>
        <td id="rundragover">
          <div class="block" id=""></div>
        </td>
        <td>
          <div class="block">
            <img
              id="runonerror"
              src="sdf.jpg"
              alt="onerror()"
              srcset=""
            />
            <p id="error"></p>
          </div>
        </td>
      </tr>
    </table>
    <%- include('JS/script') %>
  </body>
</html>
